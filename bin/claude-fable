#!/usr/bin/env bash
# claude-fable — Launch Claude Code with Fable-class behavioral discipline
PROMPT_FILE="$HOME/.claude/fable-emulation-prompt.md"

if [ ! -f "$PROMPT_FILE" ]; then
    echo "Error: $PROMPT_FILE not found" >&2
    exit 1
fi

exec claude --append-system-prompt-file "$PROMPT_FILE" --dangerously-skip-permissions --remote-control "$@"
